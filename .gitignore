# Environment variables - never commit these
.env
.env.local
.env.production
backend/.env

# Dependencies
node_modules/
*/node_modules/

# Build outputs
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Word temp files
~$*

# Python cache
__pycache__/
*.pyc

# Backups
backups/

# Thesis documents and figures (root-level only - leftover from the old
# thesis repo; unscoped versions of these rules used to also swallow real
# app files like frontend/public/index.html without anyone noticing)
/*.docx
/*.pdf
/*.xlsx
/*.png
/*.html
/*.drawio
/*.txt
/*.py

# ...except README screenshots
!docs/screenshots/*.png

# Backup files
*.bak

# One-off local scripts (not part of the app)
/generate_class_diagram.js
/generate_erd.js
/backend/load_test.js
