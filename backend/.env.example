DB_USER=postgres
DB_HOST=localhost
DB_NAME=mis_db
DB_PASSWORD=your_postgres_password
DB_PORT=5432

# Any long random string works. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Origin allowed to make credentialed requests (CORS). Must match exactly
# where the frontend is served from — no trailing slash. Defaults to
# http://localhost:3000 if unset.
FRONTEND_URL=http://localhost:3000

# Optional — password-reset emails are logged to the console if these are unset.
# Get free sandbox credentials at https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
